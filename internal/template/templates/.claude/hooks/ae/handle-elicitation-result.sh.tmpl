#!/bin/bash
# AE ElicitationResult Hook Wrapper - Generated by ae-adk
# This script forwards stdin JSON to the ae hook elicitation-result command.
# Project-local hook: .claude/hooks/ae/handle-elicitation-result.sh

# Create temp file to store stdin
temp_file=$(mktemp)
trap 'rm -f "$temp_file"' EXIT

# Read stdin into temp file
cat > "$temp_file"

# Try ae command in PATH
if command -v ae &> /dev/null; then
	exec ae hook elicitation-result < "$temp_file"
fi

# Try detected Go bin path from initialization
if [ -f "{{posixPath .GoBinPath}}/ae" ]; then
	exec "{{posixPath .GoBinPath}}/ae" hook elicitation-result < "$temp_file"
fi

# Try default ~/go/bin/ae
if [ -f "{{posixPath .HomeDir}}/go/bin/ae" ]; then
	exec "{{posixPath .HomeDir}}/go/bin/ae" hook elicitation-result < "$temp_file"
fi

# Not found - exit silently (Claude Code handles missing hooks gracefully)
exit 0
