#!/bin/bash
# AE Statusline Wrapper - Generated by ae-adk
# This script forwards stdin JSON to the ae statusline command.
# Paths are configured during project initialization.

# Create temp file to store stdin
temp_file=$(mktemp)
trap 'rm -f "$temp_file"' EXIT

# Read stdin into temp file
cat > "$temp_file"

# Load GLM environment variables if configured (for Agent Teams tmux mode)
if [ -f "$HOME/.ae/.env.glm" ]; then
	# shellcheck disable=SC1091
	source "$HOME/.ae/.env.glm"
fi

# Try ae command in PATH first
if command -v ae &> /dev/null; then
	exec ae statusline < "$temp_file"
fi

# Try detected Go bin path from initialization
if [ -f "{{posixPath .GoBinPath}}/ae" ]; then
	exec "{{posixPath .GoBinPath}}/ae" statusline < "$temp_file"
fi

# Try user local bin directory
if [ -f "{{posixPath .HomeDir}}/.local/bin/ae" ]; then
	exec "{{posixPath .HomeDir}}/.local/bin/ae" statusline < "$temp_file"
fi

# Not found - exit silently (Claude Code handles missing statusline gracefully)
exit 0
